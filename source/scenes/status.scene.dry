            {!<td style="background-color: #bcdeb8;">!}[+ res_worker_scps_display +]%{!</td>!}
        {!</tr>!}
        {!<tr>!}
            {!<td>!}**Others**{!</td>!}
            {!<td style="background-color: #e7e7e7; font-size: 0.85em;">!}[+ farmers_other_display +]%{!</td>!}
