@polls
on-display: {!

setTimeout(() => {

const subgroups = ["workers", "unemployed", "farmers"];

const data = [
  {
    group: "FLP",
    workers: Q.workers_flp || 0,
    unemployed: Q.unemployed_flp || 0,
    farmers: Q.farmers_flp || 0
  },
  {
    group: "PPS",
    workers: Q.workers_pps || 0,
    unemployed: Q.unemployed_pps || 0,
    farmers: Q.farmers_pps || 0
  },
  {
    group: "LPS",
    workers: Q.workers_lps || 0,
    unemployed: Q.unemployed_lps || 0,
    farmers: Q.farmers_lps || 0
  }
];

const svg = d3.select("#my_dataviz").html("")
  .append("svg")
  .attr("width", 460)
  .attr("height", 400)
  .append("g")
  .attr("transform", "translate(50,10)");

const width = 460 - 50 - 30;
const height = 400 - 10 - 20;

const x = d3.scaleBand()
  .domain(data.map(d => d.group))
  .range([0, width])
  .padding(0.2);

svg.append("g")
  .attr("transform", "translate(0," + height + ")")
  .call(d3.axisBottom(x));

const maxY = Math.max(1, d3.max(data, d =>
  subgroups.reduce((sum, k) => sum + (d[k] || 0), 0)
));

const y = d3.scaleLinear()
  .domain([0, maxY])
  .nice()
  .range([height, 0]);

svg.append("g")
  .call(d3.axisLeft(y));

const color = d3.scaleOrdinal()
  .domain(subgroups)
  .range(["#4caf50", "#ff9800", "#2196f3"]);

const stackedData = d3.stack()
  .keys(subgroups)(data);



svg.append("g")
  .selectAll("g")
  .data(stackedData)
  .join("g")
    .attr("fill", d => color(d.key))
  .selectAll("rect")
  .data(d => d)
  .join("rect")
    .attr("x", d => x(d.data.group))
    .attr("y", d => y(d[1]))
    .attr("height", d => y(d[0]) - y(d[1]))
    .attr("width", x.bandwidth());

    console.log("DATA:", data);

}, 50);
!}

