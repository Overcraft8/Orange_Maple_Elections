title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_rounded = Q.unemployed.toFixed(1);
}

if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}

Q.economic_growth_rounded = '0';

if (Q.economic_growth) {
    Q.economic_growth_rounded = Q.economic_growth.toFixed(1);
}
!}
on-display: {!
    //data = Q.parliament_diagram;
    //console.log("Parliament Data Payload:", data);
    if (d3 && window && Q.started) {
        var data = Q.parliament_diagram;
        var screenWidth = document.getElementById('qualities').offsetWidth;
/* Old dimensions 250 and 120 */
        var width = Math.max(Math.min(screenWidth , 200), 90);
        var heightRatio = screenWidth < 350 ? 0.5 : 0.6;
        var height = width * heightRatio;

        document.getElementById("legislative_status").style.height = height + "px";

        var legislative_status = d3.parliament();
        legislative_status.width(width);
        legislative_status.height(height);
        legislative_status.innerRadiusCoef(0.4);
        legislative_status.enter.fromCenter(false).smallToBig(false);
        legislative_status.exit.toCenter(false).bigToSmall(false);
        d3.select("#legislative_status").datum(data).call(legislative_status);
}


!}

<button class="status_tab_button" id="budget_tab" onclick="window.changeTab('status.budget', 'budget_tab');">Budget</button>

= Status

<div style="text-align: center; display:flex; align-items:flex-start;"> <div style="width:60%; text-align:center;">
<img src="img/Red_Lily.png" style="max-width:100%;">
 </div>
<img src="img/portraits/[+ premier_img +]" style="width:110x;height:170px;object-fit:cover;object-position:top;border:4px ridge #8B7355;"><p></p><div style="width:60%; text-align:center;">
<img src="img/Red_Lily.png" style="max-width:100%;">
 </div></div>


<div style="display: block; font-size: 18px; font-weight: bold; text-align: center;">
    Premier: [+ premier +] ([+ premier_party +])

    Government: [+ ruling_government +]

    FLP position: [? if flp_toleration : toleration ?][? if flp_in_government : in government - ?][? if flp_toleration == 0 and flp_in_government == 0 and flp_caretaker == 0 : opposition ?][? if flp_caretaker : caretaker government ?]
    [? if in_lps_coalition and flp_in_government: Liberal-CCF Coalition ?][? if in_grand_coalition and flp_in_government: Grand Coalition ?][? if in_unity_government and flp_in_government: Popular Front ?][? if in_left_front and flp_in_government: Left Front ?][? if in_flp_majority and flp_in_government: FLP majority ?][? if in_minority_government and flp_in_government: minority government ?]

    [? if flp_in_government and not in_flp_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

    [? if flp_in_government and (in_left_front or in_unity_government): CP(S) coalition dissent: [+ cp_s_coalition_dissent : coalition_dissent +] ?]

    Prime Minister: [+ prime_minister +]
</div> 

= Legislature

Assembly composition:

 <div style="display: flex; justify-content: center; align-items: stretch;"> 
 {!<svg id="legislative_status"  style="width: 200px; height: 100px;"> </svg>!} 
 </div>

<div style='text-align: center;'>
# 1928: 30, 1930: 25, 1932: 22
[? if flp_seats > 0: [? if not flp_name: FLP?][? if flp_name != 0 : [+ flp_name +]?]{!</span>!}: [+ flp_seats +] ?]
[? if sapd_formed and sapd_r > 0: SAPD: [+ sapd_r +]% ?]
# 1928: 15, 1930: 15, 1932: 
[? if pps_seats > 0: [? if not pps_name: PPS?][? if pps_name != 0 : [+ pps_name +]?]{!</span>!}: [+ pps_seats +] ?]
# 1928: 10, 1930: 13
[? if cp_s_seats > 0: [? if not cp_s_name: CP(S)?][? if cp_s_name != 0 : [+ cp_s_name +]?]{!</span>!}: [+ cp_s_seats +] ?]
# 1928: 5, 1930: 4 (as DstP)
[? if lps_seats > 0: [? if not lps_name: LPS?][? if lps_name != 0 : [+ lps_name +]?]{!</span>!}: [+ lps_seats +] ?]
# 1928: 9, 1930: 5
[? if cps_seats > 0: [? if not cps_name: CPS?][? if cps_name != 0 : [+ cps_name +]?]{!</span>!}: [+ cps_seats +] ?]
# 1928: 14, 1930: 7
[? if scps_seats > 0: [? if not scps_name: SCPS?][? if scps_name != 0 : [+ scps_name +]?]{!</span>!}: [+ scps_seats +] ?]
# 1928: 9, 1930: 10
[? if other_seats > 0: Independents: [+ other_seats +] ?]
</div>

Budget: [+ treasury +] 

Next Legislative Election: [+ next_parl_election_month : month +] [+ next_parl_election_year +]



