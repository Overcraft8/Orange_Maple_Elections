on-display: {!


Q.tax_list = [
        { name: "Lower Brackets", val: Q.lower_tax_rates },
        { name: "Middle Brackets", val: Q.middle_tax_rates },
        { name: "Upper Brackets", val: Q.upper_tax_rates }
    ];

    // Pass the list to your function
    // Q.tax_display_html = window.get_taxes(Q.tax_list);
    Q.calculated_taxes = window.get_taxes_final(Q.tax_list);
    Q.final_taxes = window.calculate_income_tax();
!}

